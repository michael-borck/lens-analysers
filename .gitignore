# lens-analysers is a DOCS-ONLY umbrella. Each analyser/app lives in its own repo,
# cloned here as an independent working copy. Ignore EVERY nested project by
# default (so dropping a new repo in here needs no edit), and track only the docs.
/*/
!/docs/
!/scripts/

# Junk
__pycache__/
*.py[cod]
.venv/
.DS_Store
